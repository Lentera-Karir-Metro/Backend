							"mode": "raw",
							"raw": ""
						},
						"url": {
							"raw": "{{baseUrl}}/auth/sync",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"sync"
							]
						},
						"description": "Panggil ini setiap kali user login/register untuk menyimpan data ke MySQL. Body kosong saja."
