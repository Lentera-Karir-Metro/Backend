		"_postman_id": "lentera-karir-final-v2",
		"name": "Lentera Karir API (Final)",
		"description": "Koleksi API Lengkap untuk Project Lentera Karir.\nUpdated: Mendukung fitur Diskon, Mentor, Rating, dan Kategori.",
