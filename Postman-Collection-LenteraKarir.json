{
  "info": {
    "name": "LenteraKarir API (Complete & Verified)",
    "description": "Complete Postman Collection for LenteraKarir Backend covering all routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Smart Auth Switching Logic",
          "let token = pm.collectionVariables.get('user_token'); // Default to User",
          "",
          "// If URL contains '/admin', switch to Admin Token",
          "if (pm.request.url.path.join('/').includes('admin')) {",
          "    token = pm.collectionVariables.get('admin_token');",
          "}",
          "",
          "// Fallback: If specific token not found, try generic 'auth_token'",
          "if (!token) token = pm.collectionVariables.get('auth_token');",
          "",
          "if (token) {",
          "    pm.request.headers.add({key: 'Authorization', value: 'Bearer ' + token});",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"testuser@example.com\",\n    \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/v1/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
                  "try {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.token) pm.collectionVariables.set(\"verification_token\", jsonData.token);",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/verify-email?token={{verification_token}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "verify-email"],
              "query": [{ "key": "token", "value": "{{verification_token}}" }]
            }
          }
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"testuser@example.com\",\n    \"password\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"auth_token\", jsonData.token);",
                  "    pm.collectionVariables.set(\"user_token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [],
