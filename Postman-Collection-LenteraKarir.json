	"item": [
		{
			"name": "0. Auth & Setup (Supabase)",
			"item": [
				{
					"name": "1. Register User (Ke Supabase)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "apikey",
								"value": "{{anonKey}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user_baru@gmail.com\",\n  \"password\": \"Password123!\",\n  \"data\": {\n    \"username\": \"si_paling_coding\"\n  }\n}"
						},
						"url": {
							"raw": "{{supabaseUrl}}/auth/v1/signup",
							"host": [
								"{{supabaseUrl}}"
							],
							"path": [
								"auth",
								"v1",
								"signup"
							]
						},
						"description": "Mendaftar ke Supabase. JANGAN LUPA set variabel 'anonKey' dan 'supabaseUrl' di Environment Postman."
					},
					"response": []
				},
				{
					"name": "2. Login User (Dapat Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.environment.set(\"userToken\", jsonData.access_token);",
									"    console.log(\"User Token saved!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "apikey",
								"value": "{{anonKey}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user_baru@gmail.com\",\n  \"password\": \"Password123!\"\n}"
						},
						"url": {
							"raw": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
							"host": [
								"{{supabaseUrl}}"
							],
							"path": [
								"auth",
								"v1",
								"token"
							],
							"query": [
								{
									"key": "grant_type",
									"value": "password"
								}
							]
						}
					},
					"response": []
				}
			]
		},
